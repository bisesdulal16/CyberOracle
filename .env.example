# CyberOracle Environment Configuration
# Copy this file as `.env` and adjust values as needed.

# Database connection string
# Use this for LOCAL development (FastAPI runs on your host)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cyberoracle

# Use this for DOCKER deployment (FastAPI runs inside a container)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/cyberoracle

# For Discord alert (PSFR6):
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1435305674727751691/pbikFh-Qs0RbWpUye9El8cn63noVHTeHTuJ3B7YSvVLURIkc4_YG_P0hfYKF2tAeY0BK

# -------------------------------------------------------------------
# PSFR7 — Database Encryption & Key Management
# -------------------------------------------------------------------
# Turn encryption on/off without changing code.
DB_ENCRYPTION_ENABLED=false

# Symmetric encryption key (example placeholder).
# For a real key in a demo, generate one and put it here.
DB_ENCRYPTION_KEY=CHANGE_ME_TO_32_CHAR_SECURE_KEY_123456

# Logical key version (for rotation design, e.g. v1, v2...)
DB_ENCRYPTION_KEY_ID=v1

# Optional settings
# APP_DEBUG=true
# APP_ENV=development
# JWT_SECRET=your_secret_key_here

# Used by tests
PYTEST=1


# -------------------------------------------------------------------
# Added for RBAC Authentication (Section 9)
# -------------------------------------------------------------------

JWT_SECRET_KEY=adc075f073fba17cb3494b983b19819b62fba3d43a2bbb2578087585f235e587

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_admin

DEV_USERNAME=developer
DEV_PASSWORD=changeme_dev

AUDITOR_USERNAME=auditor
AUDITOR_PASSWORD=changeme_auditor


# -------------------------------------------------------------------
# Optional Alert Integration (Section 10)
# -------------------------------------------------------------------

SLACK_WEBHOOK_URL=

# -------------------------------------------------------------------
# PSPR8 — Email Alerting (SMTP)
# -------------------------------------------------------------------
# Leave blank to disable email alerts (Discord/Slack will still fire).
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

ENV=dev