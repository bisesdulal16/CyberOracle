# PostgreSQL credentials (matches docker-compose DB container)
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=cyberoracle

# Local backup directory
BACKUP_DIR=/tmp/cyberoracle-backups

# Retention: delete local backups older than this many days
RETENTION_DAYS=7

# MinIO connection (Nexus or local MinIO)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=cyberoracle-backups
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
