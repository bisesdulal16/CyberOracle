    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests (24h)",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {
        "type": "postgres",
        "uid": "cyberoracle"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "cyberoracle"},
          "format": "table",
          "rawSql": "SELECT COUNT(*)::bigint AS value FROM logs WHERE created_at >= NOW() - INTERVAL '24 hours';"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "thresholds"}}
      }
