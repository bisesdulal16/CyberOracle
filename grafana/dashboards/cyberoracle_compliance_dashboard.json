          "refId": "A",
          "datasource": {"type": "postgres", "uid": "cyberoracle"},
          "rawSql": "SELECT endpoint, COUNT(*)::bigint AS requests, COUNT(DISTINCT CASE WHEN policy_decision = 'block' THEN id END)::bigint AS blocked, COUNT(DISTINCT CASE WHEN policy_decision = 'redact' THEN id END)::bigint AS redacted FROM logs WHERE created_at >= NOW() - INTERVAL '24 hours' GROUP BY endpoint ORDER BY requests DESC LIMIT 10;"
